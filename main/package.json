{
    "name": "ian-website",
    "type": "module",
    "author": "Ian Wilson",
    "scripts": {
        "dev": "astro dev",
        "generate:types": "astro sync",
        "check": "astro check",
        "build": "rimraf dist && astro build && astro check",
        "preview": "pnpm build && astro preview",
        "preview:prod": "pnpm run build && pnpm wrangler pages dev",
        "format": "biome format --write .",
        "lint": "biome check --write ."
    },
    "dependencies": { "astro": "7.0.3" },
    "devDependencies": {
        "@astrojs/check": "0.9.9",
        "@astrojs/ts-plugin": "1.10.7",
        "@biomejs/biome": "2.4.15",
        "rimraf": "6.1.3",
        "typescript": "6.0.3",
        "wrangler": "4.105.0"
    }
}
